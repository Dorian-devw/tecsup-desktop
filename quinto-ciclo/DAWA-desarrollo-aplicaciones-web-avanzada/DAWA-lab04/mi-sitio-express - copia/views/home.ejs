<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
    <!-- Compiled and minified CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link rel="stylesheet" href="/styles.css">
    <style>
        body { 
            font-family: 'Roboto', sans-serif; 
            background-color: #fce4ec; 
            padding: 20px;
        }
        .card { 
            background-color: #f8bbd9; 
            margin: 20px 0;
            padding: 20px;
        }
        .btn { 
            background-color: #e1bee7; 
            color: #4a148c; 
            margin: 10px;
        }
        .btn:hover { background-color: #ce93d8; }
        .center-align { margin-top: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row">
            <div class="col s12">
                <div class="card">
                    <div class="card-content">
                        <h1 class="center-align">Bienvenido a la Página de Inicio</h1>
                        <div class="center-align" style="display: flex; flex-direction: column; gap: 15px; align-items: center;">
                            <a href="/about" class="btn waves-effect waves-light">Ir a Acerca de</a>
                            <a href="/contact" class="btn waves-effect waves-light">Ir a Contacto</a>
                            <a href="/admin" class="btn waves-effect waves-light">Ir a Panel de Administración</a>
                            <a href="/dota" class="btn waves-effect waves-light">Ir a Héroes de Dota 2</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Compiled and minified JavaScript -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>
